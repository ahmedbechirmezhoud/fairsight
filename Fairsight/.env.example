# Mapbox SDK download token (build-time, Android only)
# Required to pull the Mapbox Maven artifacts during `expo prebuild`.
# Maps SDK v11 usually works without it, but set it if the Android build fails.
# Generate at: https://console.mapbox.com/account/access-tokens/ (secret token, sk.ey...)
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=

# Mapbox public access token (runtime)
# Written to Android native string resources at prebuild time via app.config.ts.
# Generate at: https://console.mapbox.com/account/access-tokens/ (public token, pk.ey...)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
